{
  "name": "Numav Builder",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "runArgs": [
    "--privileged",  // Critical for mounting
    "--cap-add=SYS_ADMIN",
    "--security-opt=apparmor:unconfined"
  ],
  "settings": {
    "terminal.integrated.shell.linux": "/bin/bash"
  }
}